<!DOCTYPEhtml>
<html>
<head>
<title>Login Page</title>
<style>
body{
font-family: Arial;
background:#3498db;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}
.login-box{
background:white;
padding:30px;
border-radius:10px;
width:300px;
text-align:center;
}
input{
width:90%;
padding:10px;
margin:10px 0;
}
button{
padding:10px;
width:100%;
background:#2ecc71;
border:none;
color:white;
font-size:16px;
}
</style>
<script>
function login(){
var username = document.getElementById("username").value;
var password = document.getElementById("password").value;
if(username == "admin" && password == "1234"){
alert("Login Successful ");
}
else{
alert("Invalid Username or Password ");
}
}
</script>
</head>
<body>
<div class="login-box">
<h2>Login</h2>
<input type="text" id="username" placeholder="Enter Username">
<input type="password" id="password" placeholder="Enter Password">
<button onclick="login()">Login</button>
</div>
</body>
</html>
