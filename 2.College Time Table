<!DOCTYPEhtml>
<html>
<head>
<title>Timetable</title>
<style>
body {
font-family: Arial;
background-color: #eef2ff;
}
h2 {
text-align: center;
color: #1e3a8a;
}
table {
border-collapse: collapse;
margin: auto;
width: 95%;
background: #ffffff;
box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}
th {
background-color: #2563eb;
color: white;
}
th, td {
border: 1px solid #ddd;
padding: 10px;
text-align: center;
}
tr:nth-child(even) {
background-color: #f1f5f9;
}
/* Special columns */
td[rowspan]:nth-child(4) {
background-color: #fde68a; /* Break */
font-weight: bold;
}
td[rowspan]:nth-child(7) {
background-color: #fca5a5; /* Lunch */
font-weight: bold;
}
td[rowspan]:nth-child(10) {
background-color: #86efac; /* ADDON */
font-weight: bold;
}
</style>
</head>
<body>
<h2>MCATimetable</h2>
<table>
<tr>
<th>Day</th>
<th>8:45-9:30</th>
<th>9:30-10:15</th>
<th>10:15-10:30</th>
<th>10:30-11:15</th>
<th>11:15-12:00</th>
<th>12:00-1:00</th>
<th>1:00-1:45</th>
<th>1:45-2:30</th>
<th>2:30-3:30</th>
</tr>
<tr>
<td>Monday</td>
<td>OR</td>
<td>Python</td>
<td rowspan="5">Break</td>
<td>Web Tech</td>
<td>R</td>
<td rowspan="5">Lunch</td>
<td>DM Lab</td>
<td>IOT</td>
<td rowspan="5">ADDON</td>
</tr>
<tr>
<td>Tuesday</td>
<td>Python</td>
<td>Python Lab</td>
<td>WDLab</td>
<td>R</td>
<td>Python</td>
<td>IOT</td>
</tr>
<tr>
<td>Wednesday</td>
<td>Web Lab</td>
<td>Python</td>
<td>DM Lab</td>
<td>Web Lab</td>
<td>OR</td>
<td>SPM</td>
</tr>
<tr>
<td>Thursday</td>
<td>OR</td>
<td>Python</td>
<td>Lab</td>
<td>R</td>
<td>Python</td>
<td>IOT</td>
</tr>
<tr>
<td>Friday</td>
<td>Python</td>
<td>WDLab</td>
<td>R</td>
<td>IOT</td>
<td>OR</td>
<td>SPM</td>
</tr>
</table>
</body>
</html>
