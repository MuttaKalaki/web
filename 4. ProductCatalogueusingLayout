<h2 align="center">Cart</h2>
</nav>
<h2 align="center">Cart</h2>
<table id="t">
<tr>
<th>Image</th>
<th>Item</th>
<th>Price</th>
<th>Action</th>
</tr>
</table>
<h3 id="total" align="center"></h3>
<div style="text-align:center">
<button onclick="order()" style="background:green">Place Order</button>
</div>
<script>
let cart=JSON.parse(localStorage.getItem("cart")) |[];
let t=document.getElementById("t");
let sum=0;
cart.forEach((item,index)=>{
let r=t.insertRow();
r.insertCell(0).innerHTML="<img src='"+item.image+"'>";
r.insertCell(1).innerText=item.name;
r.insertCell(2).innerText="₹"+item.price;
let btn=document.createElement("button");
btn.innerText="Remove";
btn.onclick=function(){
cart.splice(index,1);
localStorage.setItem("cart",JSON.stringify(cart));
location.reload();
};
r.insertCell(3).appendChild(btn);
sum+=item.price;
});
document.getElementById("total").innerText="Total ₹"+sum;
function order(){
localStorage.removeItem("cart");
window.location="thankyou.html";
}
</script>
</body>
</html>

