<nav>
<div class="logo">TechStore</div>
<div class="nav-links">
<a href="index.html">Home</a>
<a href="gadgets.html">Gadgets</a>
<a href="cart.html">Cart</a>
<a href="contact.html">Contact</a>
</div>
